# Variables marked [required] are validated at build time (src/config/env.ts).
# The app will refuse to start if any are missing.
# Variables marked [optional] have safe defaults or degrade gracefully when absent.

# ─── Meta / Facebook ──────────────────────────────────────────────────────────
META_APP_ID=                    # [required] Facebook App ID (from developers.facebook.com)
META_APP_SECRET=                # [required] Facebook App Secret — never client-side
META_SYSTEM_ACCESS_TOKEN=       # [required] Long-lived system user token for cron + Slack bot — never client-side
META_AD_ACCOUNT_ID=             # [optional] Primary ad account (format: act_XXXXXXXXX or raw numeric ID)
META_AD_ACCOUNT_IDS=            # [optional] Multi-account cron mode: comma-separated IDs (e.g. act_111,act_222)
NEXT_PUBLIC_FACEBOOK_PAGE_ID=   # [optional] Facebook Page ID used when creating ad creatives

# ─── Slack ────────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=                # [required] xoxb-... bot token (OAuth scopes: chat:write, channels:read)
SLACK_SIGNING_SECRET=           # [required] Used for HMAC request signature verification on all inbound webhooks
SLACK_CLIENT_ID=                # [optional] Slack app client ID (for OAuth flow)
SLACK_CLIENT_SECRET=            # [optional] Slack app client secret (for OAuth flow) — never client-side
SLACK_NOTIFICATION_CHANNEL=     # [optional] Default channel for launch/budget alerts (e.g. C0XXXXXXXXX or #alerts)

# ─── AI ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=              # [required] Anthropic API key for Claude chat and Slack bot analysis
ANTHROPIC_MODEL=                # [optional] Defaults to claude-sonnet-4-20250514

# ─── Storage ──────────────────────────────────────────────────────────────────
REDIS_URL=                      # [optional] Redis connection string (e.g. redis://localhost:6379 or Upstash URL)
                                #            If unset, automation rules fall back to cookie-only storage

# ─── Security ─────────────────────────────────────────────────────────────────
CRON_SECRET=                    # [optional] Bearer token required on GET /api/automations/evaluate
                                #            Must match the secret set in vercel.json cron configuration
                                #            If unset in production, the endpoint is disabled (returns 503)
ALLOWED_USER_IDS=               # [optional] Comma-separated Facebook user ID allowlist for login
                                #            If unset, any Facebook user can log in
ALLOWED_SLACK_USER_IDS=         # [optional] Comma-separated Slack user ID allowlist for bot action buttons and mentions
                                #            If unset, any workspace member can execute actions and query the bot
ALLOWED_SLACK_CHANNEL_IDS=      # [optional] Comma-separated Slack channel ID allowlist for bot mentions
                                #            If unset, the bot responds to @mentions in any channel it's in

# ─── Automation Engine ────────────────────────────────────────────────────────
AUTOMATION_MAX_ACTIONS_PER_RUN= # [optional] Max Meta actions (pause/activate/promote) per cron run — defaults to 20
                                #            Prevents a misconfigured rule from pausing all active ads in one run

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=            # [required] Canonical app URL used in OAuth redirect URIs (e.g. https://your-app.vercel.app)

# ─── Dev ──────────────────────────────────────────────────────────────────────
USE_MOCK_DATA=                  # [optional] Set to "true" to use mock ad data in development (no Meta API calls)
