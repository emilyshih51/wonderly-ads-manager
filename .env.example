# ─── Meta / Facebook ──────────────────────────────────────────────────────────
META_APP_ID=                    # Facebook App ID (from developers.facebook.com)
META_APP_SECRET=                # Facebook App Secret — never client-side
META_AD_ACCOUNT_ID=             # Primary ad account (format: act_XXXXXXXXX or raw numeric ID)
META_AD_ACCOUNT_IDS=            # Multi-account cron mode: comma-separated IDs (e.g. act_111,act_222)
META_SYSTEM_ACCESS_TOKEN=       # Long-lived system user token for cron + Slack bot — never client-side
NEXT_PUBLIC_FACEBOOK_PAGE_ID=   # Facebook Page ID used when creating ad creatives

# ─── Slack ────────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=                # xoxb-... bot token (OAuth scopes: chat:write, channels:read)
SLACK_SIGNING_SECRET=           # Used for HMAC request signature verification on all inbound webhooks
SLACK_CLIENT_ID=                # Slack app client ID (for OAuth flow)
SLACK_CLIENT_SECRET=            # Slack app client secret (for OAuth flow) — never client-side
SLACK_NOTIFICATION_CHANNEL=     # Default channel for launch/budget alerts (e.g. C0XXXXXXXXX or #alerts)

# ─── AI ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=              # Anthropic API key for Claude chat and Slack bot analysis
ANTHROPIC_MODEL=                # Optional — defaults to claude-sonnet-4-20250514

# ─── Storage ──────────────────────────────────────────────────────────────────
REDIS_URL=                      # Redis connection string (e.g. redis://localhost:6379 or Upstash URL)
                                # Optional in dev — automation rules fall back to cookie-only storage

# ─── Security ─────────────────────────────────────────────────────────────────
CRON_SECRET=                    # Bearer token required on GET /api/automations/evaluate
                                # Must match the secret set in vercel.json cron configuration
                                # Required in production — endpoint is disabled if unset
ALLOWED_EMAILS=                 # Optional comma-separated email allowlist for Facebook login
                                # If set, only these emails can log in (e.g. you@company.com,teammate@company.com)
                                # If unset, any Facebook user can log in
ALLOWED_SLACK_USER_IDS=         # Optional comma-separated Slack user ID allowlist for bot action buttons
                                # If set, only these users can trigger pause/resume/budget actions from Slack
                                # If unset, any workspace member can execute actions

# ─── Automation Engine ────────────────────────────────────────────────────────
AUTOMATION_MAX_ACTIONS_PER_RUN= # Max Meta actions (pause/activate/promote) per cron run — defaults to 20
                                # Prevents a misconfigured rule from pausing all active ads in one run

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=            # Canonical app URL used in OAuth redirect URIs (e.g. https://your-app.vercel.app)

# ─── Dev ──────────────────────────────────────────────────────────────────────
USE_MOCK_DATA=                  # Set to "true" to use mock ad data in development (no Meta API calls)
